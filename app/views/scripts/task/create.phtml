<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nueva Tarea</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <!-- Contenedor principal -->
    <div class="container mx-auto px-4 py-8 max-w-2xl">

        <!-- Header -->
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800 mb-2"> Nueva Tarea</h1>
        </div>

        <!-- Error -->
        <?php if (isset($this->view->error)): ?>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
                <?= htmlspecialchars($this->view->error) ?>
            </div>
        <?php endif; ?>

        <!-- Formulario -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <form method="POST" action="../tasks/create" class="space-y-4">

                <!-- Título -->
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Título *</label>
                    <input type="text"
                        name="titulo"
                        value="<?= htmlspecialchars($this->view->data['titulo'] ?? '') ?>"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Describe la tarea"
                        required>
                </div>

                <!-- Descripción -->
                <div>
                    <label class="block text-gray-700 font-medium mb-2">Descripción</label>
                    <textarea name="descripcion"
                        rows="3"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="Detalles de la tarea (opcional)"><?= htmlspecialchars($this->view->data['descripcion'] ?? '') ?></textarea>
                </div>

                <!-- Estado y Usuario -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Estado</label>
                        <select name="estado" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="pendiente" selected> Pendiente</option>
                            <option value="en ejecucion"> En Ejecución</option>
                            <option value="finalizada"> Finalizada</option>
                        </select>
                    </div>
                    <div>
                        <label for="usuario_id" class="block text-gray-700 font-medium mb-2">Alumno</label>
                        <select id="usuario_id" name="usuario_id" required
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <?php if (is_array($this->usuariosData) && count($this->usuariosData) > 0): ?>
                                <?php foreach ($this->usuariosData as $usuario): ?>
                                    <?php
                                    $idUsuario = $usuario['id'] ?? '';
                                    $nombreUsuario = $usuario['nombre'] ?? "Usuario #$idUsuario";
                                    $selected = (isset($this->usuarioSeleccionado) && $this->usuarioSeleccionado == $idUsuario) ? 'selected' : '';
                                    ?>
                                    <option value="<?= htmlspecialchars($idUsuario) ?>" <?= $selected ?>>
                                        <?= htmlspecialchars($nombreUsuario) ?>
                                    </option>
                                <?php endforeach; ?>
                            <?php else: ?>
                                <option disabled>No hay usuarios disponibles</option>
                            <?php endif; ?>
                        </select>

                    </div>
                </div>

                <!-- Fechas -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Fecha inicio</label>
                        <input type="datetime-local"
                            name="fecha_inicio"
                            value="<?= htmlspecialchars($this->view->data['fecha_inicio'] ?? '') ?>"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-2">Fecha límite</label>
                        <input type="datetime-local"
                            name="fecha_fin"
                            value="<?= htmlspecialchars($this->view->data['fecha_fin'] ?? '') ?>"
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>

                <!-- Botones -->
                <div class="flex justify-end space-x-3 pt-4 border-t">
                    <button type="button"
                        onclick="history.back()"
                        class="px-4 py-2 text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
                        Cancelar
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700">
                        Crear Tarea
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>

</html>