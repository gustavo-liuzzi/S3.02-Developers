<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Tareas</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col items-center p-6">

  <div class="fixed top-0 left-0 w-full h-full bg-cover bg-center blur-md opacity-[0.85] -z-10"
    style="background-image: url('images/fondo.png')"></div>
    <div class="max-w-4xl mx-auto px-4 py-8">
        
        <!-- Header -->
        <div class="mb-6 text-center">
            <h1 class="text-3xl font-bold text-gray-800">Tareas Abiertas</h1>
        </div>

        <!-- Mensaje -->
<?php if (!empty($_GET['message'])): ?>
    <div id="flashMessage"
         class="fixed top-4 left-1/2 transform -translate-x-1/2 bg-green-100 text-green-800 border border-green-300 rounded px-4 py-3 shadow z-50 max-w-lg text-center">
        <?= htmlspecialchars($_GET['message']) ?>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const flash = document.getElementById('flashMessage');
            if (flash) {
                setTimeout(() => {
                    flash.style.transition = 'opacity 0.5s ease';
                    flash.style.opacity = '0';
                    setTimeout(() => flash.remove(), 500);
                }, 3000);
            }
        });
    </script>
<?php endif; ?>

        <!-- Botón crear -->
        <div class="mb-4 text-right">
            <a href="tasks/create" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                Nueva Tarea
            </a>
        </div>

        <?php if (count($this->tasks) == 0): ?>
            <!-- Sin tareas -->
            <div class="bg-white p-8 rounded text-center shadow">
                <h3 class="text-xl mb-2">No hay tareas</h3>
                <a href="tasks/create" class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">
                    Crear primera tarea
                </a>
            </div>
        <?php else: ?>
            <!-- Lista de tareas -->
            <div class="bg-white rounded-xl shadow overflow-hidden">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="p-3 text-left">ID</th>
                            <th class="p-3 text-left">Tarea</th>
                            <th class="p-3 text-left">Estado</th>
                            <th class="p-3 text-left">Acciones</th>
                            <th class="p-3 text-left">Alumno</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($this->tasks as $task): ?>
                            <tr class="border-t hover:bg-gray-50">
                                <td class="p-3"><?= $task->id_tarea ?></td>
                                <td class="p-3">
                                    <div class="font-medium"><?= htmlspecialchars($task->titulo) ?></div>
                                    <?php if ($task->descripcion): ?>
                                        <div class="text-gray-500 text-sm">
                                            <?= strlen($task->descripcion) > 50 ? substr(htmlspecialchars($task->descripcion), 0, 50) . '...' : htmlspecialchars($task->descripcion) ?>
                                        </div>
                                    <?php endif; ?>
                                </td>
                                <td class="p-3">
                                    <?php
                                    $colors = [
                                        'pendiente' => 'bg-yellow-200 text-yellow-800',
                                        'en ejecucion' => 'bg-blue-200 text-blue-800',
                                        'completada' => 'bg-green-200 text-green-800'
                                    ];
                                    $estado = $task->estado->value;
                                    ?>
                                    <span class="px-2 py-1 rounded text-xs <?= $colors[$estado] ?? 'bg-gray-200' ?>">
                                        <?= ucfirst(str_replace('_', ' ', $estado)) ?>
                                    </span>
                                </td>
                                <td class="p-3">
                                    <a href="tasks/show?id=<?= $task->id_tarea ?>" class="text-blue-500 mr-2" title="Ver">Ver</a>
                                    <a href="tasks/edit?id=<?= $task->id_tarea ?>" class="text-yellow-500 mr-2" title="Editar">Editar</a>
                                    <a href="tasks/delete?id=<?= $task->id_tarea ?>" class="text-red-600 hover:text-red-800 text-sm" title="Eliminar">Eliminar</a>
                                </td>
                                <td class="p-3">
                                    <?php if ($task->usuario_id): ?>
                                        <a href="usuarios/<?= $task->usuario_id ?>" class="text-indigo-500">
                                            Alumno #<?= htmlspecialchars($task->usuario_id) ?>
                                        </a>
                                    <?php else: ?>
                                        <span class="text-gray-500">Sin asignar</span>
                                    <?php endif; ?>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
                
                <!-- Resumen -->
                <div class="bg-gray-50 p-3 text-sm text-gray-600 border-t">
                </div>
            </div>
        <?php endif; ?>
    </div>
</body>
</html>
