<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Tarea</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen py-8">
    <div class="max-w-2xl mx-auto px-4">

        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Editar Tarea</h1>
            <a href="../tasks" class="text-blue-600">← Volver</a>
        </div>

        <?php if (!empty($this->error)): ?>
            <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
                <?= htmlspecialchars($this->error) ?>
            </div>
        <?php endif; ?>

        <?php $task = $this->task ?? null; ?>

        <?php if ($this->task): ?>
            <div class="bg-white rounded shadow p-6">
                <form method="POST" action="<?= htmlspecialchars($_SERVER['REQUEST_URI']) ?>">


                    <input type="hidden" name="id_tarea" value="<?= htmlspecialchars($task->id_tarea) ?>">

                    <div class="mb-4">
                        <label class="block text-gray-700 mb-2" for="titulo">Título</label>
                        <input type="text" id="titulo" name="titulo" value="<?= htmlspecialchars($task->titulo) ?>"
                            class="w-full px-3 py-2 border rounded" required>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 mb-2" for="descripcion">Descripción</label>
                        <textarea id="descripcion" name="descripcion" rows="3"
                            class="w-full px-3 py-2 border rounded"><?= htmlspecialchars($task->descripcion) ?></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 mb-2" for="estado">Estado</label>
                        <select id="estado" name="estado" class="w-full px-3 py-2 border rounded">
                            <option value="pendiente" <?= ($task->estado->value ?? '') === 'pendiente' ? 'selected' : '' ?>>Pendiente</option>
                            <option value="en ejecucion" <?= ($task->estado->value ?? '') === 'en ejecucion' ? 'selected' : '' ?>>En Ejecución</option>
                            <option value="finalizada" <?= ($task->estado->value ?? '') === 'finalizada' ? 'selected' : '' ?>>Finalizada</option>
                        </select>
                    </div>

                    <div>
                        <label for="usuario_id" class="block text-gray-700 font-medium mb-2">Alumno</label>
                        <select id="usuario_id" name="usuario_id" required
                            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <?php if (is_array($this->usuariosData) && count($this->usuariosData) > 0): ?>
                                <?php foreach ($this->usuariosData as $usuario): ?>
                                    <?php
                                    $idUsuario = $usuario['id'] ?? '';
                                    $nombreUsuario = $usuario['nombre'] ?? "Usuario #$idUsuario";
                                    $selected = (isset($this->usuarioSeleccionado) && $this->usuarioSeleccionado == $idUsuario) ? 'selected' : '';
                                    ?>
                                    <option value="<?= htmlspecialchars($idUsuario) ?>" <?= $selected ?>>
                                        <?= htmlspecialchars($nombreUsuario) ?>
                                    </option>
                                <?php endforeach; ?>
                            <?php else: ?>
                                <option disabled>No hay usuarios disponibles</option>
                            <?php endif; ?>
                        </select>

                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 mb-2" for="fecha_inicio">Fecha inicio</label>
                        <input type="datetime-local" id="fecha_inicio" name="fecha_inicio"
                            value="<?= $task->fecha_inicio ? date('Y-m-d\TH:i', strtotime($task->fecha_inicio)) : '' ?>"
                            class="w-full px-3 py-2 border rounded">
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 mb-2" for="fecha_fin">Fecha límite</label>
                        <input type="datetime-local" id="fecha_fin" name="fecha_fin"
                            value="<?= $task->fecha_fin ? date('Y-m-d\TH:i', strtotime($task->fecha_fin)) : '' ?>"
                            class="w-full px-3 py-2 border rounded">
                    </div>

                    <div class="flex justify-end space-x-3">
                        <button type="button"
                            class="px-4 py-2 text-gray-600 border rounded hover:bg-gray-50"
                            onclick="history.back()">
                            Cancelar
                        </button>
                        <button type="submit"
                            class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                            Guardar
                        </button>
                    </div>
                </form>
            </div>
        <?php else: ?>
            <div class="bg-red-100 text-red-700 p-6 rounded">
                <h3 class="font-bold mb-2">Error: Tarea no encontrada</h3>
                <p>No se pudo cargar la tarea para editar.</p>
                <a href="../tasks" class="text-blue-600 underline">← Volver al listado</a>
            </div>
        <?php endif; ?>
    </div>
</body>

</html>