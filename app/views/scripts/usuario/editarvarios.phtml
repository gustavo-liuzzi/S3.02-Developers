<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <title>Editar alumnos</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
</head>

<?php if (!empty($_SESSION['flash_message'])): ?>
  <div id="flashMessage" class="mb-4 px-4 py-3 bg-green-100 text-green-800 rounded border border-green-300 shadow text-center fixed top-4 left-1/2 transform -translate-x-1/2 z-50 max-w-lg">
    <?= htmlspecialchars($_SESSION['flash_message']); ?>
  </div>
  <?php unset($_SESSION['flash_message']); ?>
<?php endif; ?>

<body class="bg-gray-100 min-h-screen flex flex-col items-center p-6">

  <div class="fixed top-0 left-0 w-full h-full bg-cover bg-center blur-md opacity-[0.85] -z-10"
    style="background-image: url('images/fondo.png')"></div>

  <h1 class="text-3xl font-extrabold mb-8 text-indigo-700 drop-shadow z-10">Editar alumnos seleccionados</h1>

  <?php if (is_iterable($this->usuarios ?? null) && count($this->usuarios) > 0): ?>
    <form method="POST" action="guardaractualizaciones" class="w-full max-w-6xl bg-white p-8 rounded-2xl shadow-2xl border border-indigo-200 z-10">

      <?php foreach ($this->usuarios as $u): ?>
        <fieldset class="mb-8 border border-indigo-300 rounded-xl p-6 shadow-md">
          <legend class="font-semibold text-lg text-indigo-700 mb-4">
            Alumno ID <?= htmlspecialchars($u['id']) ?>
          </legend>

          <input type="hidden" name="usuarios[<?= $u['id'] ?>][id]" value="<?= htmlspecialchars($u['id']) ?>">

          <label class="block text-sm font-semibold text-indigo-700 mb-1" for="nombre-<?= $u['id'] ?>">Nombre</label>
          <input type="text"
            id="nombre-<?= $u['id'] ?>"
            name="usuarios[<?= $u['id'] ?>][nombre]"
            value="<?= htmlspecialchars($u['nombre']) ?>"
            class="w-full border border-indigo-300 rounded-lg px-3 py-2 mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" required>

          <label class="block text-sm font-semibold text-indigo-700 mb-1" for="email-<?= $u['id'] ?>">Email</label>
          <input type="email"
            id="email-<?= $u['id'] ?>"
            name="usuarios[<?= $u['id'] ?>][email]"
            value="<?= htmlspecialchars($u['email']) ?>"
            class="w-full border border-indigo-300 rounded-lg px-3 py-2 mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" required>

          <p class="text-sm text-indigo-400 italic">[ ** Contraseña no modificable por mentor ** ]</p>
        </fieldset>
      <?php endforeach; ?>

      <div class="text-center mt-6">
        <button type="button"
          onclick="history.back()"
          class="px-4 py-2 text-gray-600 border border-gray-700 rounded-md hover:bg-gray-50">
          Cancelar
        </button>
        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl shadow transition">
          Guardar cambios
        </button>
      </div>
    </form>
  <?php else: ?>
    <div class="bg-red-100 text-red-700 px-6 py-4 rounded shadow text-center max-w-md z-10 mt-8">
      <p>No se han encontrado datos de usuarios válidos para editar.</p>
    </div>
  <?php endif; ?>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const flash = document.getElementById('flashMessage');
      if (flash) {
        setTimeout(() => {
          flash.style.transition = 'opacity 0.5s ease';
          flash.style.opacity = '0';
          setTimeout(() => flash.remove(), 500);
        }, 3000);
      }
    });
  </script>

</body>

</html>