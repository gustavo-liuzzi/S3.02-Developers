<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Tareas de <?= htmlspecialchars($this->usuario['nombre'] ?? 'Usuario') ?></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">

    <h1 class="text-2xl font-bold mb-4">Tareas del alumno: <?= htmlspecialchars($this->usuario['nombre'] ?? 'Usuario') ?></h1>
    <?php
    // Aseguramos que $this->tareas existe y tenga un formato iterable
    $tareas = $this->tareas ?? [];

    // Si es objeto y no array, intentamos convertir a array
    if (is_object($tareas) && !is_array($tareas)) {
        if ($tareas instanceof Traversable) {
            $tareas = iterator_to_array($tareas);
        } else {
            $tareas = (array)$tareas;
        }
    }
?>

<?php if (count($tareas) === 0): ?>
    <p>No hay tareas asignadas a este usuario.</p>
<?php else: ?>
    <table class="min-w-full bg-white rounded shadow overflow-hidden">
        <thead class="bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
            <tr>
                <th class="py-3 px-6 text-left">ID Tarea</th>
                <th class="py-3 px-6 text-left">Título</th>
                <th class="py-3 px-6 text-left">Descripción</th>
                <th class="py-3 px-6 text-left">Estado</th>
                <th class="py-3 px-6 text-left">Fecha Inicio</th>
                <th class="py-3 px-6 text-left">Fecha Fin</th>
            </tr>
        </thead>
        <tbody class="text-gray-600 text-sm">
            <?php foreach ($tareas as $task): ?>
                <tr class="border-b border-gray-200 hover:bg-gray-100">
                    <td class="py-3 px-6"><?= htmlspecialchars($task->id_tarea) ?></td>
                    <td class="py-3 px-6"><?= htmlspecialchars($task->titulo) ?></td>
                    <td class="py-3 px-6"><?= nl2br(htmlspecialchars($task->descripcion)) ?></td>
                    <td class="py-3 px-6"><?= htmlspecialchars($task->estado->value ?? $task->estado) ?></td>
                    <td class="py-3 px-6"><?= htmlspecialchars($task->fecha_inicio) ?></td>
                    <td class="py-3 px-6"><?= htmlspecialchars($task->fecha_fin) ?></td>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
<?php endif; ?>


    <div class="mt-4">
        <a href="../modules" class="text-blue-600 hover:underline">← Volver al listado de usuarios</a>
    </div>

</body>
</html>
