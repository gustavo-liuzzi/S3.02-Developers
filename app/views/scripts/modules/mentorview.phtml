<?php endif; ?>

<body class="bg-gray-100 min-h-screen flex flex-col items-center p-6">

  <div class="fixed top-0 left-0 w-full h-full bg-cover bg-center blur-md opacity-[0.85] -z-10"
    style="background-image: url('images/fondo.png')"></div>

  <h1 class="text-3xl font-extrabold mb-4 text-indigo-700 drop-shadow z-10">Lista de alumnos</h1>

  <!-- Select para ordenación -->
  <div class="w-full max-w-6xl mb-6 z-10 text-right pr-4 md:pr-0">
    <label for="ordenar" class="text-sm font-medium text-indigo-700 mr-2">Ordenar por:</label>
    <select id="ordenar"
      class="bg-white border border-indigo-300 rounded px-3 py-1 text-sm text-indigo-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
      <option value="id" selected>Nº Alumno</option>
      <option value="nombre">Nombre (A-Z)</option>
      <option value="email">Email (A-Z)</option>
    </select>
  </div>

  <?php $usuarios = $this->usuarios ?? []; ?>

  <?php if (!empty($usuarios)): ?>
    <form method="POST" action="eliminaralumnos" id="formAlumnos" class="relative w-full max-w-6xl z-10">
      <div id="contenedorTarjetas" class="bg-white p-6 rounded-2xl shadow-2xl border border-indigo-200 overflow-auto"
        style="max-height: 70vh;">
        <div id="usuarios" class="flex flex-wrap gap-5 justify-center">
          <?php foreach ($usuarios as $u): ?>
            <div
              class="relative group rounded-xl p-4 w-full sm:w-1/3 md:w-1/4 lg:w-1/5 transition-transform duration-200 hover:scale-105 cursor-pointer bg-gradient-to-br from-indigo-500 via-indigo-600 to-indigo-700 hover:from-black hover:to-black shadow-md flex flex-col items-center gap-2">

              <input type="checkbox" name="seleccionados[]" value="<?= $u['id'] ?>"
                class="absolute top-3 left-3 h-5 w-5 text-indigo-600 bg-white rounded focus:ring-0 focus:ring-offset-0" />

              <a href="<?= WEB_ROOT . '/usuarios/' . $u['id'] ?>"
                class="flex flex-col items-center gap-2 w-full h-full pt-6 text-white no-underline hover:underline">

                <div class="flex items-center justify-center w-10 h-10 rounded-full bg-indigo-200 text-indigo-800 text-base font-bold mb-2 select-none">
                  <?= htmlspecialchars($u['id']) ?>
                </div>

                <p class="font-semibold text-lg"><?= htmlspecialchars($u['nombre']) ?></p>

                <p class="text-xs"><?= htmlspecialchars($u['email']) ?></p>

              </a>
            </div>
          <?php endforeach; ?>
        </div>
      </div>

      <!-- Contenedor botones debajo, distribuidos horizontalmente -->
      <div class="mt-6 flex justify-between max-w-6xl w-full space-x-4">
        <a href="tasks/create"
          class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded shadow text-center whitespace-normal break-words">
          Crear Tarea
        </a>

        <a href="tasks"
          class="flex-1 bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded shadow text-center whitespace-normal break-words">
          Ver Todas las tareas
        </a>

        <button type="submit" formaction="modificaralumnos" form="formAlumnos"
          class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded shadow disabled:opacity-50 disabled:cursor-not-allowed whitespace-normal break-words"
          id="btnModificar" disabled>
          Modificar Alumno/s
        </button>

        <button type="button"
          class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded shadow disabled:opacity-50 disabled:cursor-not-allowed whitespace-normal break-words"
          id="btnEliminar" disabled>
          Eliminar Alumno/s
        </button>
      </div>
    </form>
  <?php else: ?>
    <p class="text-gray-700 z-10">No hay alumnos.</p>
  <?php endif; ?>

  <!-- Modal confirmación para eliminación -->
  <div id="confirmModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-lg p-6 max-w-sm w-full shadow-xl text-center">
      <h2 class="text-xl font-semibold text-red-600 mb-4">¡Atención!</h2>
      <p class="text-gray-800 mb-6">
        Los alumnos seleccionados y sus tareas asociadas serán eliminados. ¿Desea continuar?
      </p>
      <div class="flex justify-center gap-4">
        <button id="confirmYes" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">Sí</button>
        <button id="confirmNo" class="bg-gray-300 text-gray-800 px-4 py-2 rounded hover:bg-gray-400">No</button>
      </div>
    </div>
  </div>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      console.log("Script cargado");

      Sortable.create(document.getElementById('usuarios'), {
        animation: 150
      });

      const btnEliminar = document.getElementById('btnEliminar');
      const btnModificar = document.getElementById('btnModificar');
      const form = document.getElementById('formAlumnos');
      const checkboxes = document.querySelectorAll('input[type="checkbox"][name="seleccionados[]"]');

      checkboxes.forEach(c => {
        c.addEventListener('change', () => {
          const algunoSeleccionado = Array.from(checkboxes).some(ch => ch.checked);
          btnEliminar.disabled = !algunoSeleccionado;
          btnModificar.disabled = !algunoSeleccionado;
        });
      });

      const modal = document.getElementById('confirmModal');
      const confirmYes = document.getElementById('confirmYes');
      const confirmNo = document.getElementById('confirmNo');

      btnEliminar.addEventListener('click', () => {
        console.log("Eliminar pulsado");
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      });

      confirmYes.addEventListener('click', () => {
        console.log("Confirmación: enviando formulario");
        document.body.classList.remove('overflow-hidden');
        modal.classList.add('hidden');
        form.submit();
      });

      confirmNo.addEventListener('click', () => {
        console.log("Cancelado");
        document.body.classList.remove('overflow-hidden');
        modal.classList.add('hidden');
      });

      const cardsContainer = document.getElementById('usuarios');
      const selectOrden = document.getElementById('ordenar');

      // Ordenar por defecto ID
      const ordenarTarjetas = (criterio) => {
        const cards = Array.from(cardsContainer.children);

        cards.sort((a, b) => {
          if (criterio === 'id') {
            const aId = parseInt(a.querySelector('div.w-10')?.textContent.trim() || '0', 10);
            const bId = parseInt(b.querySelector('div.w-10')?.textContent.trim() || '0', 10);
            return aId - bId;
          } else {
            const selector = (criterio === 'nombre') ? 'p.font-semibold' : 'p.text-xs';
            const aTexto = a.querySelector(selector)?.textContent.toLowerCase().trim() || '';
            const bTexto = b.querySelector(selector)?.textContent.toLowerCase().trim() || '';
            return aTexto.localeCompare(bTexto);
          }
        });

        cards.forEach(card => cardsContainer.appendChild(card));
      }

      ordenarTarjetas('id');

      selectOrden.addEventListener('change', function () {
        ordenarTarjetas(this.value);
      });
    });
  </script>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const flash = document.getElementById('flashMessage');
      if (flash) {
        setTimeout(() => {
          flash.style.transition = 'opacity 0.5s ease';
          flash.style.opacity = '0';
          setTimeout(() => flash.remove(), 500);
        }, 3000);
      }
    });
  </script>

</body>

</html>
